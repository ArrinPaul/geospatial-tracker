# ══════════════════════════════════════════════════════════════════════
#  VISION API KEYS — Fallback Chain (tried in order, top to bottom)
#  Priority: FREE providers first → PAID providers last
# ══════════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────┐
# │  1. GROQ (PRIMARY) — FREE                                     │
# │     Model: llama-4-scout-17b-16e-instruct (vision)             │
# │     Limits: 30 RPM, 14,400 req/day, 6,000 tokens/min           │
# │     Signup: https://console.groq.com                           │
# └─────────────────────────────────────────────────────────────────┘
GROQ_API_KEY=your_groq_key

# ┌─────────────────────────────────────────────────────────────────┐
# │  2. TOGETHER AI — FREE                                        │
# │     Model: meta-llama/Llama-Vision-Free                        │
# │     Limits: 60 RPM, ~1,000 req/day on free models              │
# │     Signup: https://api.together.xyz                           │
# └─────────────────────────────────────────────────────────────────┘
TOGETHER_API_KEY=your_together_key

# ┌─────────────────────────────────────────────────────────────────┐
# │  3. GOOGLE GEMINI — FREE (Flash model only)                    │
# │     Model: gemini-2.0-flash (NOT gemini-3.1-pro which is PAID) │
# │     Limits: 15 RPM, 1,500 req/day on free tier                 │
# │     Signup: https://ai.google.dev                              │
# │     ⚠ gemini-3.1-pro = PAID ($3.50/M input, $10.50/M output)  │
# │     ✅ gemini-2.0-flash = FREE (used in this project)           │
# └─────────────────────────────────────────────────────────────────┘
GEMINI_API_KEY=your_gemini_key

# ┌─────────────────────────────────────────────────────────────────┐
# │  4. OPENAI — 💰 PAID (last resort)                             │
# │     Model: gpt-4o-mini                                         │
# │     Cost: ~$0.15/M input + $0.60/M output tokens               │
# │     Only used if ALL free providers above are exhausted         │
# │     Leave blank to never use paid fallback                     │
# └─────────────────────────────────────────────────────────────────┘
OPENAI_API_KEY=


# ══════════════════════════════════════════════════════════════════════
#  MAP — Mapbox (FREE: 50,000 map loads/month)
# ══════════════════════════════════════════════════════════════════════
MAPBOX_TOKEN=your_mapbox_token

# ══════════════════════════════════════════════════════════════════════
#  SATELLITE — Sentinel Hub (FREE: 30,000 tiles/month)
# ══════════════════════════════════════════════════════════════════════
SENTINEL_INSTANCE_ID=

# ══════════════════════════════════════════════════════════════════════
#  AIRCRAFT DATA
# ══════════════════════════════════════════════════════════════════════
# OpenSky Network — FREE (no key needed, optional auth for higher limits)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
# ADS-B Exchange — 💰 PAID
ADSBX_API_KEY=
# AviationStack — FREE (100 req/month)
AVIATIONSTACK_API_KEY=

# ══════════════════════════════════════════════════════════════════════
#  POLLING
# ══════════════════════════════════════════════════════════════════════
DETECTION_CYCLE_INTERVAL=10
